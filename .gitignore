# ==============================================================================
#  ATHENA — .gitignore
#  Everything install.sh downloads or builds stays OUT of the repo. What IS
#  committed: source (orpheus/*.cpp, patches/), scripts, docs, confs, the
#  emotion2vec conversion script. Models, ONNX Runtime, the two upstream trees,
#  build outputs, and runtime state are all produced by install.sh.
# ==============================================================================

# ── Models (~179 GB — downloaded by install.sh) ───────────────────────────────
/models/*
!/models/.gitkeep
!/models/emotion2vec-reexport.py
/models/emotion2vec-reexport.out
/models/.emotion-venv/

# SNAC decoder (downloaded into orpheus/) + ORT optimized-graph cache
/orpheus/snac24_dynamic_fp16.onnx
/orpheus/*.optimized

# ── ONNX Runtime (downloaded + extracted by install.sh) ───────────────────────
/onnxruntime-linux-x64-gpu_cuda12-*/
/onnxruntime-*.tgz

# ── Upstream sources (cloned + built in-tree by install.sh) ───────────────────
/llama.cpp/
/whisper.cpp/

# ── Build outputs ─────────────────────────────────────────────────────────────
/orpheus/build/
*.o
*.optimized

# Compiled forensic helper (source athena-kmsg-logger.cpp IS committed; binary is not)
/athena-kmsg-logger

# Desktop launchers — generated by install.sh from the committed *.desktop.in templates
/Athena 397B.desktop
/athena-autostart.desktop

# ── Runtime state / diagnostics / logs ────────────────────────────────────────
/athena-diag/
/athena_memory/*
!/athena_memory/.gitkeep
*.log
/speak_tts.txt
/speak_tts.done
/speak_tts.stop
/speakfile.temp
/orpheus_tts.wav

# ── Editor / OS cruft ─────────────────────────────────────────────────────────
*.swp
*~
.DS_Store
.idea/
.vscode/
