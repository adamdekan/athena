[Desktop Entry]
# ATHENA auto-relaunch after a panic auto-reboot (CHANGES.MD §16 Fix 5 — OPTIONAL, staged).
# With kernel.panic=30 armed, a worst-case crash costs ~9 min unattended (30 s panic
# + ~60 s boot + ~7.3 min model load); this entry closes the loop by relaunching
# ATHENA at desktop login. Per-turn state snapshots + cross-session memory bound
# conversational loss to <1 turn.
#
# This file is generated by install.sh from athena-autostart.desktop.in with the
# real repo path substituted for @ATHENA_DIR@.
# ENABLE:  cp @ATHENA_DIR@/athena-autostart.desktop ~/.config/autostart/
# DISABLE: rm ~/.config/autostart/athena-autostart.desktop
#
# ⚠ CAVEAT: launch-athena-397b.sh uses sudo for GPU/system tuning and will BLOCK on a
# password prompt in this terminal. For truly unattended relaunch, grant targeted
# NOPASSWD for the specific commands (nvidia-smi, sysctl, tee, cpupower...) in
# /etc/sudoers.d/athena — otherwise this simply opens the terminal and waits for you.
Type=Application
Name=Athena 397B (auto-relaunch)
Comment=Relaunch ATHENA after an unattended reboot
Exec=x-terminal-emulator -e bash -c "GGML_CUDA_NO_PINNED=1 ATHENA_MPS=1 '@ATHENA_DIR@/launch-athena-397b.sh' 2>&1 | ts '[%%Y-%%m-%%d %%H:%%M:%%.S]' | tee '@ATHENA_DIR@/athena.log'"
Icon=@ATHENA_DIR@/athena-icon.jpg
Terminal=false
X-GNOME-Autostart-enabled=true
